generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
  MEMBER
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  status        UserStatus @default(PENDING)
  role          UserRole   @default(MEMBER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts          Account[]
  sessions          Session[]
  instances         Instance[]
  runningLogs       RunningLog[]
  instanceLifecycle InstanceLifecycle[]
  costLimits        CostLimit[]
  autoStopPolicy    AutoStopPolicy?
  instanceConfig    UserInstanceConfig?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum InstanceStatus {
  PENDING
  RUNNING
  STOPPED
  STOPPING
  STARTING
  TERMINATED
  FAILED
}

model Instance {
  id              String         @id @default(cuid())
  userId          String
  name            String?
  instanceId      String?        @unique
  instanceType    String         @default("t3.small")
  status          InstanceStatus @default(PENDING)
  publicIp        String?
  privateIp       String?
  securityGroupId String?
  keyPairName     String?
  amiId           String?
  alarmName       String?
  templateId      String?
  lastActivityAt  DateTime?
  launchedAt      DateTime?
  stoppedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    InstanceTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sshKey      SshKey?
  runningLogs RunningLog[]

  @@index([userId])
  @@index([status])
}

model InstanceTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  instanceType String
  volumeSize   Int      @default(200)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  minInstances Int      @default(0)
  maxInstances Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  instances Instance[]

  @@index([isActive])
}

model CostLimit {
  id             String    @id @default(cuid())
  userId         String
  limitType      String
  limitAmount    Float
  isActive       Boolean   @default(true)
  notifyAt       Float?
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model AutoStopPolicy {
  id             String   @id @default(cuid())
  userId         String   @unique
  isActive       Boolean  @default(true)
  idleMinutes    Int      @default(720)
  checkCpu       Boolean  @default(true)
  cpuThreshold   Float    @default(5.0)
  stopOnWeekends Boolean  @default(false)
  stopAtNight    Boolean  @default(false)
  nightStartHour Int?     @default(22)
  nightEndHour   Int?     @default(6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model RunningLog {
  id          String    @id @default(cuid())
  userId      String
  instanceId  String
  startedAt   DateTime
  stoppedAt   DateTime?
  durationMin Int?
  createdAt   DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([instanceId])
  @@index([startedAt])
}

model SshKey {
  id          String   @id @default(cuid())
  instanceId  String   @unique
  keyPairName String
  privateKey  String   @db.Text
  fingerprint String?
  createdAt   DateTime @default(now())

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model InstanceLifecycle {
  id             String    @id @default(cuid())
  userId         String
  instanceType   String
  awsInstanceId  String?
  volumeSize     Int
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  deletionReason String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model UserInstanceConfig {
  id            String   @id @default(cuid())
  userId        String   @unique
  instanceQuota Int      @default(0)
  instanceType  String   @default("t3.small")
  updatedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SshAllowedIp {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String
  createdAt DateTime @default(now())

  @@unique([userId, ipAddress])
  @@index([userId])
}
